AGENT_DATABASE_URL=sqlite:///./data/agent.db
# Analytics store (uploaded data lives here, separate from app metadata)
AGENT_ANALYTICS_DB_PATH=./data/agent-analytics.db

# LLM provider — auto-detected from whichever key is set below.
# Override explicitly: anthropic | gemini
# AGENT_LLM_PROVIDER=gemini

# Override model (uses provider default when blank):
# AGENT_LLM_MODEL=gemini-3.1-pro       (Gemini default; gemini-2.5-flash = cheaper)
# AGENT_LLM_MODEL=claude-sonnet-4-6    (Anthropic default)

# Set exactly ONE provider key:
AGENT_ANTHROPIC_API_KEY=
AGENT_GEMINI_API_KEY=

PORT=8001

# Analyst guardrails (defaults shown — uncomment to change)
# AGENT_MAX_UPLOAD_MB=120
# AGENT_SQL_TIMEOUT_S=8
# AGENT_MAX_SQL_ITERATIONS=4
# AGENT_RESULT_ROW_CAP=200

# Sandbox-only escape hatch: skips real-LLM tests where the provider is
# unreachable. NEVER set this when running the phase gate — skipped is not passed.
# AGENT_SKIP_LLM_TESTS=1
