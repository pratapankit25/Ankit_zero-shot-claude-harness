AGENT_DATABASE_URL=sqlite:///./data/agent.db
# Analytics store (uploaded + synced data lives here, separate from app metadata)
AGENT_ANALYTICS_DB_PATH=./data/agent-analytics.db

# LLM provider — auto-detected from whichever key is set below.
# Override explicitly: anthropic | gemini
# AGENT_LLM_PROVIDER=gemini

# Override model (auto-falls back to a model your key supports on 404):
# AGENT_LLM_MODEL=gemini-2.5-flash

# Set exactly ONE provider key:
AGENT_ANTHROPIC_API_KEY=
AGENT_GEMINI_API_KEY=

PORT=8001

# ---------- Phase 3: MsSQL nightly sync (read-only login recommended) ----------
# Daytime questions NEVER touch this server — only the scheduled extract does.
# AGENT_MSSQL_HOST=
# AGENT_MSSQL_PORT=1433
# AGENT_MSSQL_DATABASE=
# AGENT_MSSQL_USERNAME=
# AGENT_MSSQL_PASSWORD=
# AGENT_SYNC_HOUR=2                # server local hour for the nightly extract

# ---------- Phase 4: email delivery of scheduled briefs ----------
# AGENT_SMTP_HOST=
# AGENT_SMTP_PORT=587
# AGENT_SMTP_USERNAME=
# AGENT_SMTP_PASSWORD=
# AGENT_SMTP_FROM=analyst@example.in
# AGENT_SMTP_TLS=1

# ---------- Phase 4: cost estimates (₹ per 1M tokens; shown to admins) ----------
# AGENT_PRICE_INPUT_PER_M=26.0
# AGENT_PRICE_OUTPUT_PER_M=105.0

# Analyst guardrails (defaults shown — uncomment to change)
# AGENT_MAX_UPLOAD_MB=120
# AGENT_SQL_TIMEOUT_S=8
# AGENT_MAX_SQL_ITERATIONS=4
# AGENT_RESULT_ROW_CAP=200

# Sandbox-only escape hatch: skips real-LLM tests where the provider is
# unreachable. NEVER set this when running the phase gate — skipped is not passed.
# AGENT_SKIP_LLM_TESTS=1
